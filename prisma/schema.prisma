generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  MANAGER
  EMPLOYEE
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Locale {
  ar
  en
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum OfferScope {
  PRODUCT
  CATEGORY
}

enum FulfilmentType {
  DELIVERY
  PICKUP
}

enum PaymentMethod {
  CASH_ON_DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum InventoryMovementType {
  MANUAL_IN
  MANUAL_OUT
  ORDER_CONFIRM
  ORDER_CANCEL
  ADJUSTMENT
}

enum CouponApplicability {
  ALL
  DELIVERY_ONLY
  PICKUP_ONLY
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReviewReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum CampaignDestinationType {
  OFFER
  CATEGORY
  PRODUCT
  COUPON
  CART
  NONE
  CHECKOUT
  ORDERS
  SEARCH
  EXTERNAL_URL
  INTERNAL_ROUTE
}

enum CampaignPlacement {
  HOME_HERO
  HOME_SLIDER
  HOME_STRIP
  HOME_CATEGORY_STRIP
  HOME_MIDDLE
  HOME_BOTTOM
  CATEGORY_TOP
  CATEGORY_INLINE
  PRODUCT_TOP
  PRODUCT_AFTER_IMAGES
  PRODUCT_BEFORE_DESCRIPTION
  PRODUCT_BOTTOM
  OFFERS_TOP
  SEARCH_TOP
  CART_TOP
  CART_BOTTOM
  CHECKOUT_TOP
  CHECKOUT_BOTTOM
  ORDER_SUCCESS
}

enum CampaignLayout {
  HERO_BANNER
  SMALL_BANNER
  STRIP_BANNER
  SQUARE_CARD
  POPUP
  COUPON_CARD
  FLOATING_BANNER
  FLASH_SALE_CARD
}

enum CampaignAudience {
  ALL
  GUEST_ONLY
  LOGGED_IN_ONLY
}

enum CampaignFrequency {
  ALWAYS
  ONCE
  DAILY
  EVERY_LAUNCH
  EVERY_SESSION
  DISMISS_HOURS
}

enum CampaignRotationMode {
  PRIORITY
  WEIGHT
  RANDOM
}

enum CampaignCtaStyle {
  PRIMARY
  SECONDARY
  OUTLINE
  TEXT
  PILL
}

enum CampaignTextAlign {
  START
  CENTER
  END
}

enum CampaignEventType {
  IMPRESSION
  CLICK
}

enum NotificationType {
  ORDER_STATUS
  OFFER
  ADMIN
  SYSTEM
}

model User {
  id                     String        @id @default(uuid())
  email                  String?       @unique
  phone                  String?       @unique
  passwordHash           String?
  googleSub              String?       @unique
  fullName               String
  avatarPath             String?
  role                   UserRole      @default(CUSTOMER)
  status                 AccountStatus @default(ACTIVE)
  locale                 Locale        @default(ar)
  emailVerifiedAt        DateTime?
  phoneVerifiedAt        DateTime?
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  deletedAt              DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  addresses        Address[]
  refreshTokens    RefreshToken[]
  cart             Cart?
  orders           Order[]
  notifications    Notification[]
  deviceTokens     DeviceToken[]
  reviews             ProductReview[]
  reviewReplies       ProductReview[]      @relation("ReviewReplies")
  reviewModerations   ProductReview[]      @relation("ReviewModerations")
  reviewReports       ReviewReport[]       @relation("ReviewReports")
  resolvedReports     ReviewReport[]       @relation("ResolvedReviewReports")
  couponUsages        CouponUsage[]
  inventoryMoves      InventoryMovement[]  @relation("InventoryMovedBy")
  statusChanges       OrderStatusHistory[] @relation("StatusChangedBy")
  searchHistory       UserSearchHistory[]
  wishlistItems       WishlistItem[]

  @@index([role])
  @@index([status])
  @@index([deletedAt])
}

model RefreshToken {
  id                String    @id @default(uuid())
  userId            String
  tokenHash         String    @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  userAgent         String?
  ip                String?
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

model Address {
  id            String    @id @default(uuid())
  userId        String
  label         String
  recipientName String
  phone         String
  city          String    @default("Al Khafji")
  district      String
  street        String
  building      String?
  floor         String?
  apartment     String?
  directions        String?
  formattedAddress  String?
  googlePlaceId     String?
  latitude          Decimal?  @db.Decimal(10, 7)
  longitude         Decimal?  @db.Decimal(10, 7)
  isDefault         Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt])
}

model Category {
  id        String    @id @default(uuid())
  parentId  String?
  nameAr    String
  nameEn    String
  imagePath String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")
  products Product[]
  offers   Offer[]

  @@index([isActive, sortOrder])
  @@index([parentId])
}

model Product {
  id                String    @id @default(uuid())
  categoryId        String
  nameAr            String
  nameEn            String
  descriptionAr     String?
  descriptionEn     String?
  sku               String?   @unique
  unit              String
  hasVariants       Boolean   @default(false)
  regularPrice      Decimal   @db.Decimal(10, 2)
  salePrice         Decimal?  @db.Decimal(10, 2)
  isActive          Boolean   @default(true)
  isFeatured        Boolean   @default(false)
  isBestSeller      Boolean   @default(false)
  lowStockThreshold     Int       @default(5)
  ratingAverage         Decimal   @default(0) @db.Decimal(3, 2)
  ratingCount           Int       @default(0)
  adminImageReviewedAt  DateTime?
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  category   Category         @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  variants   ProductVariant[]
  inventory  Inventory?
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews       ProductReview[]
  offerLinks    OfferProduct[]
  wishlistItems WishlistItem[]

  @@index([categoryId, isActive])
  @@index([isFeatured])
  @@index([isBestSeller])
  @@index([adminImageReviewedAt])
}

model UserSearchHistory {
  id         String   @id @default(uuid())
  userId     String
  term       String
  termKey    String
  searchedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, termKey])
  @@index([userId, searchedAt])
}

model PopularSearch {
  id             String   @id @default(uuid())
  term           String
  termKey        String   @unique
  count          Int      @default(0)
  lastSearchedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([count, lastSearchedAt])
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, createdAt])
  @@index([productId])
}

model ProductImage {
  id            String    @id @default(uuid())
  productId     String
  path          String
  sortOrder     Int       @default(0)
  isPrimary     Boolean   @default(false)
  sourceUrl     String?
  attribution   String?
  photographer  String?
  sourceProvider String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductVariant {
  id         String    @id @default(uuid())
  productId  String
  nameAr     String
  nameEn     String
  sku        String?   @unique
  price      Decimal   @db.Decimal(10, 2)
  salePrice  Decimal?  @db.Decimal(10, 2)
  isActive   Boolean   @default(true)
  sortOrder  Int       @default(0)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory  Inventory?
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId, isActive])
}

model Inventory {
  id               String   @id @default(uuid())
  productId        String?  @unique
  variantId        String?  @unique
  quantity         Int      @default(0)
  reservedQuantity Int      @default(0)
  updatedAt        DateTime @updatedAt

  product   Product?            @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant?     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  movements InventoryMovement[]
}

model InventoryMovement {
  id              String                @id @default(uuid())
  inventoryId     String
  type            InventoryMovementType
  quantityChange  Int
  quantityAfter   Int
  orderId         String?
  note            String?
  createdByUserId String?
  createdAt       DateTime              @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("InventoryMovedBy", fields: [createdByUserId], references: [id])

  @@index([inventoryId, createdAt])
  @@index([orderId])
}

model Offer {
  id            String       @id @default(uuid())
  titleAr       String
  titleEn       String
  scope         OfferScope
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  categoryId    String?
  startsAt      DateTime
  endsAt        DateTime
  isActive      Boolean      @default(true)
  imagePath     String?
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  category Category?      @relation(fields: [categoryId], references: [id])
  products OfferProduct[]

  @@index([isActive, startsAt, endsAt])
}

model OfferProduct {
  offerId   String
  productId String

  offer   Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([offerId, productId])
}

model Coupon {
  id                String               @id @default(uuid())
  code              String               @unique
  discountType      DiscountType
  discountValue     Decimal              @db.Decimal(10, 2)
  minOrderAmount    Decimal?             @db.Decimal(10, 2)
  maxDiscountAmount Decimal?             @db.Decimal(10, 2)
  usageLimit        Int?
  perUserLimit      Int?
  startsAt          DateTime
  expiresAt         DateTime
  applicability     CouponApplicability  @default(ALL)
  isActive          Boolean              @default(true)
  deletedAt         DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  usages CouponUsage[]
}

model CouponUsage {
  id             String   @id @default(uuid())
  couponId       String
  userId         String
  orderId        String   @unique
  discountAmount Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  @@index([couponId, userId])
}

model Campaign {
  id                 String                  @id @default(uuid())
  titleAr            String
  titleEn            String
  subtitleAr         String?
  subtitleEn         String?
  imagePath          String?
  iconPath           String?
  isActive           Boolean                 @default(true)
  startsAt           DateTime
  endsAt             DateTime
  sortOrder          Int                     @default(0)
  priority           Int                     @default(0)
  weight             Int                     @default(1)
  rotationMode       CampaignRotationMode    @default(PRIORITY)
  maxImpressions     Int?
  maxClicks          Int?
  layout             CampaignLayout          @default(HERO_BANNER)
  audience           CampaignAudience        @default(ALL)
  frequency          CampaignFrequency       @default(ALWAYS)
  dismissHours       Int?
  targetCities       String[]                @default([])
  targetBranchIds    String[]                @default([])
  targetCategoryIds  String[]                @default([])
  targetProductIds   String[]                @default([])
  targetOfferIds     String[]                @default([])
  targetCouponIds    String[]                @default([])
  minCartAmount      Decimal?                @db.Decimal(12, 2)
  maxCartAmount      Decimal?                @db.Decimal(12, 2)
  backgroundColor    String?
  gradientFrom       String?
  gradientTo         String?
  badgeTextAr        String?
  badgeTextEn        String?
  discountBadgeAr    String?
  discountBadgeEn    String?
  ctaStyle           CampaignCtaStyle        @default(PRIMARY)
  textAlign          CampaignTextAlign       @default(START)
  overlayOpacity     Float?                  @default(0.35)
  cornerRadius       Int?                    @default(16)
  destinationType    CampaignDestinationType @default(NONE)
  destinationId      String?
  destinationUrl     String?
  destinationRoute   String?
  autoApplyCoupon    Boolean                 @default(false)
  buttonLabelAr      String?
  buttonLabelEn      String?
  impressionCount    Int                     @default(0)
  clickCount         Int                     @default(0)
  lastViewedAt       DateTime?
  lastClickedAt      DateTime?
  deletedAt          DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  placements CampaignPlacementAssignment[]
  events     CampaignEvent[]

  @@index([isActive, startsAt, endsAt, sortOrder])
  @@index([sortOrder])
  @@index([priority])
  @@index([layout])
}

model CampaignPlacementAssignment {
  id         String            @id @default(uuid())
  campaignId String
  placement  CampaignPlacement
  createdAt  DateTime          @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, placement])
  @@index([placement])
}

model CampaignEvent {
  id         String             @id @default(uuid())
  campaignId String
  type       CampaignEventType
  placement  CampaignPlacement?
  userId     String?
  sessionId  String?
  createdAt  DateTime           @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, type, createdAt])
  @@index([createdAt])
}

model Cart {
  id             String          @id @default(uuid())
  userId         String          @unique
  couponCode     String?
  fulfilmentType FulfilmentType?
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String    @id @default(uuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
}

model Order {
  id                 String         @id @default(uuid())
  orderNumber        String         @unique
  userId             String
  status             OrderStatus    @default(PENDING)
  fulfilmentType     FulfilmentType
  paymentMethod      PaymentMethod  @default(CASH_ON_DELIVERY)
  subtotal           Decimal        @db.Decimal(10, 2)
  discountAmount     Decimal        @default(0) @db.Decimal(10, 2)
  deliveryFee        Decimal        @default(0) @db.Decimal(10, 2)
  total              Decimal        @db.Decimal(10, 2)
  couponSnapshot     Json?
  addressSnapshot    Json?
  storeSnapshot      Json?
  customerNote       String?
  cancellationReason String?
  cancelledAt        DateTime?
  confirmedAt        DateTime?
  completedAt        DateTime?
  estimatedReadyAt   DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user           User                 @relation(fields: [userId], references: [id])
  items          OrderItem[]
  statusHistory  OrderStatusHistory[]
  couponUsage    CouponUsage?

  @@index([userId, createdAt])
  @@index([status])
}

model OrderItem {
  id            String   @id @default(uuid())
  orderId       String
  productId     String
  variantId     String?
  productNameAr String
  productNameEn String
  variantNameAr String?
  variantNameEn String?
  unit          String
  sku           String?
  imagePath     String?
  unitPrice     Decimal  @db.Decimal(10, 2)
  lineDiscount  Decimal  @default(0) @db.Decimal(10, 2)
  lineTotal     Decimal  @db.Decimal(10, 2)
  quantity      Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order   Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product            @relation(fields: [productId], references: [id])
  variant ProductVariant?    @relation(fields: [variantId], references: [id])
  review  ProductReview?

  @@index([orderId])
}

model OrderStatusHistory {
  id              String       @id @default(uuid())
  orderId         String
  fromStatus      OrderStatus?
  toStatus        OrderStatus
  changedByUserId String?
  note            String?
  createdAt       DateTime     @default(now())

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User? @relation("StatusChangedBy", fields: [changedByUserId], references: [id])

  @@index([orderId, createdAt])
}

model DeliverySettings {
  id                    String   @id @default(uuid())
  isEnabled             Boolean  @default(true)
  fee                   Decimal  @db.Decimal(10, 2)
  freeDeliveryThreshold Decimal? @db.Decimal(10, 2)
  minOrderAmount        Decimal  @db.Decimal(10, 2)
  estimatedMinutesMin   Int
  estimatedMinutesMax   Int
  serviceCity           String   @default("Al Khafji")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model PickupSettings {
  id                  String   @id @default(uuid())
  isEnabled           Boolean  @default(true)
  minOrderAmount      Decimal  @db.Decimal(10, 2)
  estimatedMinutesMin Int
  estimatedMinutesMax Int
  storeNameAr         String
  storeNameEn         String
  addressAr           String
  addressEn           String
  latitude            Decimal  @db.Decimal(10, 7)
  longitude           Decimal  @db.Decimal(10, 7)
  workingHoursJson    Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  titleAr   String
  titleEn   String
  bodyAr    String
  bodyEn    String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  deletedAt DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model DeviceToken {
  id         String    @id @default(uuid())
  userId     String
  token      String    @unique
  platform   String?
  locale     Locale?
  lastSeenAt DateTime  @default(now())
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProductReview {
  id            String       @id @default(uuid())
  productId     String
  userId        String
  orderItemId   String       @unique
  rating        Int
  comment       String?
  status        ReviewStatus @default(PENDING)
  isVisible     Boolean      @default(false)
  replyText     String?
  replyByUserId String?
  repliedAt     DateTime?
  moderatedAt   DateTime?
  moderatedById String?
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  product     Product        @relation(fields: [productId], references: [id])
  user        User           @relation(fields: [userId], references: [id])
  orderItem   OrderItem      @relation(fields: [orderItemId], references: [id])
  replyByUser User?          @relation("ReviewReplies", fields: [replyByUserId], references: [id])
  moderatedBy User?          @relation("ReviewModerations", fields: [moderatedById], references: [id])
  reports     ReviewReport[]

  @@unique([userId, orderItemId])
  @@index([productId, status, isVisible])
  @@index([userId, deletedAt])
  @@index([createdAt])
}

model ReviewReport {
  id             String             @id @default(uuid())
  reviewId       String
  reporterId     String
  reason         String
  status         ReviewReportStatus @default(OPEN)
  resolutionNote String?
  resolvedAt     DateTime?
  resolvedById   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  review     ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter   User          @relation("ReviewReports", fields: [reporterId], references: [id])
  resolvedBy User?         @relation("ResolvedReviewReports", fields: [resolvedById], references: [id])

  @@unique([reviewId, reporterId])
  @@index([status, createdAt])
  @@index([reviewId])
}

model AppSettings {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  userId       String?
  userRole     String?
  userEmail    String?
  action       String
  entityType   String
  entityId     String?
  previousValues Json?
  newValues    Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([action])
}
