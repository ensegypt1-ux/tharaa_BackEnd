# =============================================================================
# Tharaa Market API — environment template
# Copy to `.env` and replace every placeholder before running.
# Never commit real secrets.
# =============================================================================

NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
API_PREFIX=api/v1

# PostgreSQL (must match docker-compose / hosted DB)
POSTGRES_USER=tharaa
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=tharaa_market
POSTGRES_PORT=55432
DATABASE_URL=postgresql://tharaa:CHANGE_ME_DB_PASSWORD@localhost:55432/tharaa_market?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (use long random strings in production; min 32 characters)
JWT_ACCESS_SECRET=CHANGE_ME_JWT_ACCESS_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET_MIN_32_CHARS
JWT_REFRESH_EXPIRES=30d

# Google Sign-In client IDs (comma-separated). Leave empty to disable.
GOOGLE_CLIENT_IDS=

# Local file storage
STORAGE_ROOT=./storage
STORAGE_PUBLIC_BASE_URL=http://localhost:3000/static
MAX_UPLOAD_BYTES=5242880
ALLOWED_IMAGE_MIMES=image/jpeg,image/png,image/webp

# Firebase Cloud Messaging (optional). Leave empty to disable push.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
# Paste the full private key on one line using \n for newlines.
FCM_PRIVATE_KEY=

# CORS — comma-separated origins for browsers
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Admin dashboard origins (merged with CORS_ORIGINS)
ADMIN_DASHBOARD_ORIGINS=http://localhost:3001

THROTTLE_TTL=60
THROTTLE_LIMIT=100

DEFAULT_CITY=Al Khafji
DEFAULT_LOCALE=ar

# Seed admin (required for `npm run prisma:seed`)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PHONE=+966500000000
SEED_ADMIN_PASSWORD=CHANGE_ME_SEED_ADMIN_PASSWORD
SEED_ADMIN_NAME=Tharaa Admin

# Pexels (optional, backend-only; never expose to clients)
PEXELS_API_KEY=

# E2E tests only (`npm run test:e2e`)
E2E_EMPLOYEE_PASSWORD=CHANGE_ME_E2E_EMPLOYEE_PASSWORD
